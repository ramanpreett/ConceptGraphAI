## Backend environment variables
# Copy to .env (do NOT commit .env)

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.abcd.mongodb.net/conceptgraph?retryWrites=true&w=majority"

# Frontend origin used for CORS. Example:
# FRONTEND_URL="https://your-frontend.vercel.app"
FRONTEND_URL="https://conceptgraphai.onrender.com"

PORT=5000
